import random
import time

#  Creates a data structure with 300+ random elements
data = [random.randint(1, 1000) for _ in range(300)]

#  Selection Sort function
def selection_sort(arr):
    arr = arr.copy()  # making a copy to keep original data
    n = len(arr)
    for i in range(n):
        min_idx = i
        for j in range(i+1, n):
            if arr[j] < arr[min_idx]:
                min_idx = j
        arr[i], arr[min_idx] = arr[min_idx], arr[i]
    return arr

# Measures performance
start_time = time.time()
sorted_data = selection_sort(data)
end_time = time.time()

print(f"Selection Sort took {end_time - start_time:.6f} seconds")
print("First 20 sorted elements:", sorted_data[:20])